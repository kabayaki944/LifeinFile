<base:WindowBase x:Class="LifeinFile.Windows.CageWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:base="clr-namespace:LifeinFile.Windows"
                 Title="Cage" Height="300" Width="400"
                 WindowStyle="ToolWindow" AllowsTransparency="False" Background="White" Topmost="True">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Debug">
            
                <MenuItem Header="Save" Click="MenuItem_DebugSave_Click"/>
            
            </MenuItem>
        </ContextMenu>
    </Window.ContextMenu>
    
    <Border BorderBrush="Gray" BorderThickness="5" CornerRadius="10"/>
</base:WindowBase>