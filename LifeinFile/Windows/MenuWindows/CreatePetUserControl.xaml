<UserControl x:Class="LifeinFile.Windows.CreatePetUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300" Height="250">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

        <TextBlock Grid.Row ="0" Text="Petの新規作成" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="名前を入力してください:" Margin="0,0,0,5" FontSize="12" Foreground="Gray"/>
            <TextBox x:Name="PetNameInput" Width="200" Height="30" FontSize="14" VerticalContentAlignment="Center"/>
            
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="作成" Width="80" Height="35" Margin="0,0,10,0" Click="CreateButton_Click"/>
            <Button Content="戻る" Width="80" Height="35" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>