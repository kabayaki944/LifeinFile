<base:WindowBase x:Class="LifeinFile.Windows.PetWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:base="clr-namespace:LifeinFile.Windows"
                 Title="Pet" Height="120" Width="100"
                 WindowStyle="None" AllowsTransparency="True" Background="Transparent" Topmost="True">
    
    <Grid MouseEnter="Grid_MouseEnter" MouseLeave="Grid_MouseLeave" Background="Transparent">

        <Image Source="/Assets/Graphic/Pets/TestCat.png" />

        <ProgressBar x:Name="HungerGauge" 
             Width="60" Height="10" 
             Minimum="0" Maximum="100" Value="100"
             Foreground="Orange" 
             VerticalAlignment="Top" HorizontalAlignment="Center" 
             Margin="0,5,0,0"
             Visibility="Hidden" />
    </Grid>
</base:WindowBase>